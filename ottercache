groups = {}
for entry in os.scandir(output_dir):
    if not entry.is_dir():
        continue
    m = date_re.match(entry.name)
    if not m:
        continue
    prefix, date, suffix = m.groups()
    key = f'{prefix}_{suffix}'
    groups.setdefault(key, []).append((date, entry.name, entry.path))

# Keep only the newest version per group; remove the rest
pruned = []
for versions in groups.values():
    if len(versions) <= 1:
        continue
    versions.sort(key=lambda v: v[0], reverse=True)   # newest first
    for _date, name, path in versions[1:]:
        shutil.rmtree(path)
        pruned.append(name)

print(json.dumps(pruned))
